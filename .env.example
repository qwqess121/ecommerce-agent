# ============ LLM 配置 ============
# 提供方：openai 或 deepseek（均兼容 OpenAI SDK）
LLM_PROVIDER=openai
# 你的 API Key（必填才能走真实大模型；留空则自动使用内置 Mock 生成器）
LLM_API_KEY=
# 接口地址与模型名
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 若使用 DeepSeek，取消下面注释并注释掉上面的 openai 段：
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ============ Embedding 配置（OpenAI 兼容） ============
# 用于向量检索；留空则系统自动回退为「纯 BM25 关键词检索」（无需联网即可运行）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# ============ 检索与生成 ============
TOP_K=5
RERANK=false

# ============ 服务 ============
HOST=127.0.0.1
PORT=8000
